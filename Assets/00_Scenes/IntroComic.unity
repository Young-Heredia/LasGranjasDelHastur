  panels:
  - {fileID: 21300000, guid: c75e01c9c01c0f94db84ee53c91fe0ab, type: 3}
  - {fileID: 21300000, guid: 98a58fb1b54b2c845b42840679c1db3e, type: 3}
  - {fileID: 21300000, guid: 1fd53e36e136ed342b306904dec26a28, type: 3}
  - {fileID: 21300000, guid: 85004967bcc847b4dbeaa790b24634d9, type: 3}
  - {fileID: 21300000, guid: 2db35f0696f124046be91d6e51cc5154, type: 3}
  - {fileID: 21300000, guid: c01efa5b538eb2d4485d51ec37ca76b6, type: 3}
  narrations:
  - "En los confines del vac\xEDo, Hastur, el Rey Amarillo, observa mundos enteros
    como si fueran simples recursos de su imperio."
  - "Ciudades, almas y recuerdos son comprimidos en ofrendas para alimentar a entidades
    antiguas que esperan m\xE1s all\xE1 de las estrellas."
  - "En los calabozos abandonados, los cultos levantan rituales para iniciar la producci\xF3n
    de almas y energ\xEDa pura."
  - "Un nuevo administrador recibe el contrato amarillo: dirigir las granjas interdimensionales
    y mantener activa la econom\xEDa de Hastur."
  - "Cuando la producci\xF3n crezca, incluso lunas, planetas, cometas y estrellas
    ser\xE1n cosechados como recursos."
  - "La granja despierta. Produce, vende, mejora y paga los impuestos c\xF3smicos...
    o ser\xE1s devorado por tus propias deudas."
  delayPerCharacter: 0.035
  narrationBlipEveryNChars: 0
  mainMenuSceneName: MainMenu
  saveIntroAsSeen: 1
